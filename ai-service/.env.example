APP_NAME=ai-service
APP_PORT=8002
DATABASE_URL=postgresql://postgres:password@localhost:5432/wisebot_ai_database
EMBEDDING_BASE_URL=http://localhost:8001
EMBEDDING_SEARCH_PATH=/v1/search
USER_SERVICE_BASE_URL=http://localhost:8080
SYSTEM_SETTING_MODE_PATH=/internal/system-settings/ai.provider_mode
INTERNAL_CONFIG_API_KEY=change-me
AI_PROVIDER_MODE=ollama
AI_PROVIDER_NAME=Ollama Local
OLLAMA_PROVIDER_NAME=Ollama Local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3:latest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
THIRD_PARTY_PROVIDER_NAME=DeepSeek API
THIRD_PARTY_BASE_URL=https://api.openai.com/v1
THIRD_PARTY_API_KEY=
THIRD_PARTY_LLM_MODEL=gpt-4o-mini
THIRD_PARTY_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=768
DEFAULT_TOP_K=5
DEFAULT_TEMPERATURE=0.2
MIN_SIMILARITY_SCORE=0.25
MAX_TOKENS=1024

# ── RAG Feature Toggles ─────────────────────────────────
QUERY_REWRITING_ENABLED=true
MULTI_QUERY_ENABLED=true
MULTI_QUERY_COUNT=3
DYNAMIC_TOP_K_ENABLED=true
TOP_K_SPECIFIC=3
TOP_K_GENERAL=8
HYBRID_SEARCH_ENABLED=true
RERANKING_ENABLED=true
JUDGE_ENABLED=true
JUDGE_USE_SHARED_LLM=false

AUTH_ENABLED=true
SERVICE_JWT_SECRET=change-me
SERVICE_JWT_ALGORITHM=HS256
SERVICE_JWT_ISSUER=wisebot
SERVICE_JWT_AUDIENCE=
ALLOWED_SERVICE_SUBJECTS=api-gateway,chat-service
