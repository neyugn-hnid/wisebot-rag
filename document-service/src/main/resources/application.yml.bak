server:
  port: 8081
  compression:
    enabled: true
    mime-types: application/json

spring:
  application:
    name: document-service

  profiles:
    active: ${SPRING_PROFILES_ACTIVE:dev}

  datasource:
    url: jdbc:postgresql://${DATABASE_HOST:localhost}:${DATABASE_PORT:5432}/${DATABASE_NAME:wisebot_document_database}
    username: ${DATABASE_USERNAME:postgres}
    password: ${DATABASE_PASSWORD:password}
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: none
    show-sql: false
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
        format_sql: true

  flyway:
    enabled: true
    locations: classpath:db/migration
    baseline-on-migrate: true
    validate-on-migrate: true
    clean-disabled: true
    out-of-order: false

  servlet:
    multipart:
      max-file-size: 25MB
      max-request-size: 25MB

  devtools:
    add-properties: true

# STORAGE CONFIG
storage:
  enabled: true
  base-path: ${STORAGE_BASE_PATH:./data/uploads}

# CHUNKING CONFIG
chunking:
  chunk-size: 800
  overlap: 120

# EMBEDDING CONFIG
embedding:
  base-url: ${EMBEDDING_BASE_URL:http://localhost:8001}
  path: /embed

# JWT CONFIG
jwt:
  expiryMinutes: ${JWT_EXPIRY_MINUTES:60}
  expiryDay: ${JWT_EXPIRY_DAY:14}
  accessKey: ${JWT_ACCESS_KEY:VYW20sDO+am1aOTsq/4Tn48CZ6oEV13ooo51rDrz7AI=}
  refreshKey: ${JWT_REFRESH_KEY:UYDDaHfHJxiTtOfyGkRbae6KlWwufFFvxA04gh/9uZI=}

# SWAGGER / OPENAPI
springdoc:
  api-docs:
    enabled: true
  swagger-ui:
    enabled: true

openapi:
  service:
    api-docs: document-service
    server: ${BACKEND_HOST:http://localhost:${server.port}}
    title: Document Service API
    description: API documentation for Document Service
    version: 1.0.0

# ACTUATOR (monitoring)
management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics

# LOGGING
logging:
  level:
    root: INFO
    org.springframework: INFO
    org.hibernate.SQL: DEBUG