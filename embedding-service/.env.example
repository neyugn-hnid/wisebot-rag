APP_NAME=embedding-service
APP_PORT=8001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wisebot
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=1536
DEFAULT_CHUNK_SIZE=1200
DEFAULT_CHUNK_OVERLAP=200
DEFAULT_COLLECTION_NAME=default

AUTH_ENABLED=true
SERVICE_JWT_SECRET=change-me
SERVICE_JWT_ALGORITHM=HS256
SERVICE_JWT_ISSUER=wisebot
SERVICE_JWT_AUDIENCE=
ALLOWED_SERVICE_SUBJECTS=api-gateway,document-service,chat-service
