@startuml
title Sơ đồ trình tự - Đăng ký tài khoản

actor "Khách truy cập" as Guest
participant "Giao diện Web" as UI
participant "User Service" as UserService
database "CSDL" as DB
participant "Email Service" as EmailService

Guest -> UI : Mở màn hình đăng ký
UI --> Guest : Hiển thị form đăng ký

Guest -> UI : Nhập họ tên, email, mật khẩu\nvà nhấn Đăng ký
UI -> UserService : Gửi yêu cầu đăng ký

UserService -> UserService : Kiểm tra dữ liệu đầu vào

alt Dữ liệu không hợp lệ
  UserService --> UI : Thông báo lỗi dữ liệu
  UI --> Guest : Hiển thị lỗi
else Dữ liệu hợp lệ
  UserService -> DB : Kiểm tra email đã tồn tại chưa
  DB --> UserService : Kết quả kiểm tra

  alt Email đã tồn tại
    UserService --> UI : Thông báo email đã tồn tại
    UI --> Guest : Hiển thị lỗi
  else Email hợp lệ và chưa tồn tại
    UserService -> UserService : Tạo tenant mặc định\nhoặc gắn tenant từ lời mời
    UserService -> UserService : Sinh OTP xác thực email
    UserService -> DB : Lưu tài khoản mới
    DB --> UserService : Lưu thành công
    UserService -> EmailService : Gửi email chứa OTP
    EmailService --> UserService : Kết quả gửi email

    alt Gửi email thất bại
      UserService --> UI : Thông báo đăng ký chưa hoàn tất
      UI --> Guest : Hiển thị lỗi
    else Gửi email thành công
      UserService --> UI : Đăng ký thành công,\nyêu cầu xác thực email
      UI --> Guest : Hiển thị thông báo thành công
    end
  end
end

@enduml
