# ======================================================
# WISEBOT-RAG - Environment Variables (.env)
# Copy this file to .env and fill in your values
# ======================================================

# ── Database ───────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-to-a-strong-password-123

# ── JWT Authentication ─────────────────────────────────
JWT_ACCESS_KEY=change-me
JWT_REFRESH_KEY=change-me
SERVICE_JWT_SECRET=change-me

# ── Internal API Keys ──────────────────────────────────
INTERNAL_API_KEY=change-me
INTERNAL_CONFIG_API_KEY=change-me

# ── AI / LLM ───────────────────────────────────────────
# Mode: ollama | third-party
AI_PROVIDER_MODE=ollama
OLLAMA_LLM_MODEL=llama3:latest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
THIRD_PARTY_PROVIDER_NAME=DeepSeek API
THIRD_PARTY_BASE_URL=https://api.openai.com/v1
THIRD_PARTY_LLM_MODEL=gpt-4o-mini
THIRD_PARTY_API_KEY=

# Query rewriter can use a stronger API model while answers still use AI_PROVIDER_MODE.
# shared = use the main AI provider. api/openai-compatible/third-party = use OpenAI-compatible API.
QUERY_REWRITER_PROVIDER_MODE=shared
QUERY_REWRITER_BASE_URL=
QUERY_REWRITER_API_KEY=
QUERY_REWRITER_MODEL=
QUERY_REWRITER_PROVIDER_NAME=Query Rewriter API
RERANKER_PROVIDER_MODE=shared
RERANKER_BASE_URL=
RERANKER_API_KEY=
RERANKER_MODEL=
RERANKER_PROVIDER_NAME=Reranker API

# ── RAG Feature Toggles ─────────────────────────────────
QUERY_REWRITING_ENABLED=true
HYBRID_SEARCH_ENABLED=true
RERANKING_ENABLED=true
JUDGE_ENABLED=true
JUDGE_USE_SHARED_LLM=false

# ── Judge LLM (LLM-as-a-Judge) ─────────────────────────
# JUDGE_USE_SHARED_LLM=false
# JUDGE_LLM_API_KEY=
# JUDGE_LLM_BASE_URL=https://api.deepseek.com/
# JUDGE_LLM_MODEL=deepseek-v4-pro

# ── Email (SendGrid) ──────────────────────────────────
# SENDGRID_API_KEY=
# SENDGRID_VERIFICATION_LINK=http://localhost:3000/verify-email?token=
# SENDGRID_RESET_PASSWORD_LINK=http://localhost:3000/reset-password?token=

# ── VNPay Payment ─────────────────────────────────────
# VNPAY_TMN_CODE=
# VNPAY_HASH_SECRET=
# VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNPAY_RETURN_URL=http://localhost:3000/billing?vnpay_return=true



# ── Embedding ──────────────────────────────────────────
EMBEDDING_DIMENSION=768
